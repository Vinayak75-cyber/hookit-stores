                        <Ruler className="w-4 h-4 text-[#999999]" />
                        <div><p className="text-xs text-[#999999]">Dimensions</p><p className="text-sm font-medium">{product.length || 0} × {product.width || 0} × {product.height || 0} cm</p></div>
                      </div>
                    )}
