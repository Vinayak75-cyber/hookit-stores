                required
                className="w-full border border-[#e5e5e5] rounded-xl py-3 pl-10 pr-28 text-[#1a1a1a] placeholder-[#bbbbbb] focus:outline-none focus:border-[#1a1a1a] focus:ring-1 focus:ring-[#1a1a1a] transition-all text-sm font-mono"
