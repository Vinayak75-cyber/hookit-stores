      value: stats.uniqueCustomers.toString(),
      icon: Users,
      change: "+15%",
      up: true,
      color: "bg-orange-50 text-orange-600",
    },
  ];

  return (
    <div className="space-y-6 sm:space-y-8">
      <div>
        <h1 className="text-xl sm:text-2xl font-bold text-[#1a1a1a]">Analytics</h1>
