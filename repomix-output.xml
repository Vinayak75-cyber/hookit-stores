                  year: "numeric",
                })}
              </p>
            </div>
            <div className="bg-[#f7f7f7] rounded-xl p-4">
              <p className="text-xs text-[#999] mb-1">Plan</p>
              <p className="text-base sm:text-lg font-semibold text-[#1a1a1a] capitalize">
